{
  "buildCommand": "VERCEL=1 VITE_STORAGE_BACKEND=supabase npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/bcb/:path*",
      "destination": "https://api.bcb.gov.br/:path*"
    },
    {
      "source": "/",
      "destination": "/v1.0.7/"
    },
    {
      "source": "/v1.0.7/(.*)",
      "destination": "/v1.0.7/index.html"
    }
  ]
}
