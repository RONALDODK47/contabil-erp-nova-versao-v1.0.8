# ---------------------------------------------------------------------------
# DESENVOLVIMENTO LOCAL — Docker Postgres + MinIO
# Produção: veja .env.production.example e docs/deploy-vercel-render-supabase.md
# ---------------------------------------------------------------------------

STORAGE_BACKEND=docker
VITE_STORAGE_BACKEND=docker

POSTGRES_USER=eye
POSTGRES_PASSWORD=ALTERE_ESTA_SENHA_POSTGRES
POSTGRES_DB=eye_vision
DATABASE_URL=postgresql://eye:ALTERE_ESTA_SENHA_POSTGRES@127.0.0.1:5432/eye_vision

MINIO_ROOT_USER=eyevision
MINIO_ROOT_PASSWORD=ALTERE_ESTA_SENHA_MINIO
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=eyevision
MINIO_SECRET_KEY=ALTERE_ESTA_SENHA_MINIO
MINIO_BUCKET=eye-vision

# IA (local e produção)
GEMINI_API_KEY=MY_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Agent API (local — produção usa PORT do Render automaticamente)
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8790

# Token padrão do escritório (dados salvos sob este token)
VITE_DEFAULT_OFFICE_TOKEN=INOV

# Dev: token legado para migração automática → INOV
VITE_DEV_OFFICE_TOKEN=CL-FN14-AZ4ZV81Y

VITE_SURYA_OCR_URL=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ---------------------------------------------------------------------------
# SYNC DOCKER → SUPABASE (enviar dados locais para a nuvem)
# npm run storage:push-supabase
# ---------------------------------------------------------------------------
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres
# SUPABASE_S3_ENDPOINT=https://[ref].supabase.co/storage/v1/s3
# SUPABASE_S3_ACCESS_KEY=
# SUPABASE_S3_SECRET_KEY=
# SUPABASE_S3_BUCKET=eye-vision
# SUPABASE_SYNC_OFFICE_TOKEN=CL-FN14-AZ4ZV81Y

# ---------------------------------------------------------------------------
# SYNC SUPABASE → DOCKER (só desenvolvimento local)
# Preencha com os dados do deploy (.env.production.example) para puxar
# automaticamente o que está na nuvem para o Postgres/MinIO local.
# ---------------------------------------------------------------------------
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres
# SUPABASE_S3_ENDPOINT=https://[ref].supabase.co/storage/v1/s3
# SUPABASE_S3_ACCESS_KEY=
# SUPABASE_S3_SECRET_KEY=
# SUPABASE_S3_BUCKET=eye-vision
# SUPABASE_SYNC_OFFICE_TOKEN=

# ---------------------------------------------------------------------------
# MIGRAÇÃO FIREBASE → DOCKER (projeto legado EMPRESTIMOS-MASTER)
# Caminho padrão: Downloads\eye-vision-v1.0.4-main\...\EMPRESTIMOS-MASTER-master
# ---------------------------------------------------------------------------
# LEGACY_EYE_VISION_ROOT=C:\Users\ronaldo.silva\Downloads\eye-vision-v1.0.4-main\eye-vision-v1.0.4-main\EMPRESTIMOS-MASTER-master
# FIREBASE_MIGRATE_EMAIL=
# FIREBASE_MIGRATE_PASSWORD=
# FIREBASE_SYNC_OFFICE_TOKEN=
# FIREBASE_MIGRATE_ON_START=false
# ALLOW_DEV_MIGRATION_ROUTES=truetrue
